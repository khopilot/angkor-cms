---
interface Props {
	title: string;
	subtitle?: string;
	ctaText?: string;
	ctaUrl?: string;
	secondaryCtaText?: string;
	secondaryCtaUrl?: string;
}
const { title, subtitle, ctaText = "Get Started", ctaUrl = "/contact", secondaryCtaText, secondaryCtaUrl } = Astro.props;
---
<section class="hero">
	<div class="hero-bg"></div>
	<div class="hero-inner">
		<h1 class="hero-title">{title}</h1>
		{subtitle && <p class="hero-subtitle">{subtitle}</p>}
		<div class="hero-actions">
			<a href={ctaUrl} class="btn-primary">{ctaText}</a>
			{secondaryCtaText && <a href={secondaryCtaUrl ?? "#"} class="btn-secondary">{secondaryCtaText}</a>}
		</div>
	</div>
</section>
<style>
	.hero { position: relative; overflow: hidden; padding: 6rem 1.5rem; background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #312e81 100%); color: #fff; text-align: center; }
	.hero-bg { position: absolute; inset: 0; opacity: 0.07; background-image: radial-gradient(circle at 25% 25%, #fff 1px, transparent 1px), radial-gradient(circle at 75% 75%, #fff 1px, transparent 1px); background-size: 50px 50px; }
	.hero-inner { position: relative; max-width: 52rem; margin: 0 auto; }
	.hero-title { font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 1.5rem; }
	.hero-subtitle { font-size: clamp(1.1rem, 2.5vw, 1.4rem); color: #93c5fd; max-width: 40rem; margin: 0 auto 2.5rem; line-height: 1.6; }
	.hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
	.btn-primary { display: inline-flex; padding: 0.875rem 2rem; background: #fff; color: #0f172a; font-weight: 600; border-radius: 0.5rem; text-decoration: none; font-size: 1rem; transition: all 0.2s; box-shadow: 0 4px 14px rgba(0,0,0,0.1); }
	.btn-primary:hover { background: #e0f2fe; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }
	.btn-secondary { display: inline-flex; padding: 0.875rem 2rem; border: 2px solid rgba(255,255,255,0.3); border-radius: 0.5rem; color: #fff; text-decoration: none; font-size: 1rem; font-weight: 500; transition: all 0.2s; }
	.btn-secondary:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.5); }
</style>
