---
interface Props {
	services: Array<{ data: Record<string, unknown>; id: string }>;
	title?: string;
	subtitle?: string;
}
const { services, title = "Our Services", subtitle = "What we offer" } = Astro.props;
---
<section class="services-section">
	<div class="services-inner">
		<div class="services-header">
			<h2 class="services-title">{title}</h2>
			<p class="services-subtitle">{subtitle}</p>
		</div>
		<div class="services-grid">
			{services.map((s) => (
				<div class="service-card">
					<div class="service-icon">{String(s.data.icon || "")?.slice(0, 2) || "⚡"}</div>
					<h3 class="service-name">{String(s.data.title || s.data.name || "")}</h3>
					<p class="service-desc">{String(s.data.description || s.data.excerpt || "")}</p>
				</div>
			))}
		</div>
	</div>
</section>
<style>
	.services-section { padding: 5rem 1.5rem; background: #fff; }
	.services-inner { max-width: 72rem; margin: 0 auto; }
	.services-header { text-align: center; margin-bottom: 3rem; }
	.services-title { font-size: 2rem; font-weight: 700; color: #111827; margin-bottom: 0.5rem; }
	.services-subtitle { color: #6b7280; font-size: 1.1rem; }
	.services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
	.service-card { padding: 2rem; border-radius: 1rem; border: 1px solid #f3f4f6; background: #fafafa; transition: all 0.25s ease; }
	.service-card:hover { border-color: #dbeafe; box-shadow: 0 10px 40px rgba(59, 130, 246, 0.08); transform: translateY(-2px); }
	.service-icon { width: 3rem; height: 3rem; border-radius: 0.75rem; background: #eff6ff; color: #2563eb; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 1rem; }
	.service-card:hover .service-icon { background: #2563eb; color: #fff; }
	.service-name { font-size: 1.15rem; font-weight: 600; color: #111827; margin-bottom: 0.5rem; }
	.service-desc { color: #6b7280; font-size: 0.9rem; line-height: 1.65; }
</style>
