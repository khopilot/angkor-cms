---
interface Props {
	items: Array<{ value: string; label: string }>;
}
const { items } = Astro.props;
---
{items.length > 0 && (
	<section class="stats-section">
		<div class="stats-inner">
			{items.map((item, i) => (
				<>
					{i > 0 && <div class="stats-divider" />}
					<div class="stat-block">
						<span class="stat-value">{item.value}</span>
						<span class="stat-label">{item.label}</span>
					</div>
				</>
			))}
		</div>
	</section>
)}
<style>
	.stats-section {
		padding: 3.5rem 1.5rem;
		background: #0f172a;
	}

	.stats-inner {
		max-width: 72rem;
		margin: 0 auto;
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0;
	}

	.stat-block {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding: 1rem 2rem;
	}

	.stat-value {
		font-size: 2.5rem;
		font-weight: 800;
		color: #fff;
		letter-spacing: -0.02em;
		line-height: 1.1;
	}

	.stat-label {
		font-size: 0.85rem;
		color: #94a3b8;
		margin-top: 0.4rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.stats-divider {
		width: 1px;
		height: 3.5rem;
		background: rgba(148, 163, 184, 0.2);
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		.stats-inner {
			flex-wrap: wrap;
		}
		.stat-block {
			flex: 0 0 50%;
			padding: 1.25rem 1rem;
		}
		.stats-divider {
			display: none;
		}
	}

	@media (max-width: 480px) {
		.stat-block {
			flex: 0 0 100%;
		}
	}
</style>
