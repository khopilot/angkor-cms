---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

type Entry = { data: Record<string, unknown>; id: string };
let studies: Entry[] = [];
try {
	const result = await getEmDashCollection("case_studies");
	studies = result.entries as Entry[];
} catch { /* collection doesn't exist */ }
---

<Base title="Case Studies" description="Our work and results">
	<section class="page-hero">
		<h1 class="page-hero-title">Case Studies</h1>
		<p class="page-hero-subtitle">Real results for real businesses</p>
	</section>

	<section class="cases-page">
		{studies.length === 0 ? (
			<div class="page-placeholder">
				<p>No case studies yet. Use the AI Assistant to create some.</p>
			</div>
		) : (
			<div class="cases-grid">
				{studies.map((s) => {
					const client = String(s.data.client || s.data.company || "");
					const title = String(s.data.title || s.data.name || "Case Study");
					const desc = String(s.data.description || s.data.excerpt || "");
					const results = String(s.data.results || s.data.outcome || "");
					return (
						<div class="case-card">
							{client && <span class="case-client">{client}</span>}
							<h3 class="case-title">{title}</h3>
							{desc && <p class="case-desc">{desc}</p>}
							{results && (
								<div class="case-results">
									<span class="case-results-label">Results</span>
									<span class="case-results-text">{results}</span>
								</div>
							)}
						</div>
					);
				})}
			</div>
		)}
	</section>
</Base>

<style>
	.page-hero { padding: 5rem 1.5rem 3rem; background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #312e81 100%); color: #fff; text-align: center; }
	.page-hero-title { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; margin: 0 0 0.75rem; }
	.page-hero-subtitle { font-size: 1.1rem; color: #93c5fd; margin: 0; }
	.cases-page { max-width: 72rem; margin: 0 auto; padding: 3rem 1.5rem 5rem; }
	.cases-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.75rem; }
	.case-card { background: #fff; border-radius: 1rem; border: 1px solid #f0f0f0; border-top: 4px solid #2563eb; padding: 2rem; transition: all 0.3s ease; }
	.case-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(37, 99, 235, 0.08); }
	.case-client { display: inline-block; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #2563eb; margin-bottom: 0.75rem; }
	.case-title { font-size: 1.2rem; font-weight: 700; color: #111827; margin: 0 0 0.75rem; line-height: 1.35; }
	.case-desc { color: #6b7280; font-size: 0.92rem; line-height: 1.65; margin: 0 0 1.25rem; }
	.case-results { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 0.5rem; padding: 0.75rem 1rem; }
	.case-results-label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: #15803d; margin-bottom: 0.25rem; }
	.case-results-text { font-size: 0.88rem; color: #166534; line-height: 1.5; }
	.page-placeholder { text-align: center; padding: 3rem; color: #9ca3af; }
</style>
