---
/**
 * Dynamic Homepage — renders visual sections based on CMS collections.
 *
 * When the AI creates collections (services, team, testimonials, case_studies),
 * they automatically appear here with professional design components.
 * Falls back to a blog layout if no collections exist.
 */
// If this is the Token Press platform domain, show the landing page
const hostname = Astro.url.hostname;
if (hostname === "token-press.com" || hostname === "www.token-press.com") {
	return Astro.redirect("/token-press");
}

import { getEmDashCollection, getEmDashEntry, getEntryTerms, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import ServicesGrid from "../components/sections/ServicesGrid.astro";
import TestimonialsSection from "../components/sections/TestimonialsSection.astro";
import TeamGrid from "../components/sections/TeamGrid.astro";
import CaseStudiesGrid from "../components/sections/CaseStudiesGrid.astro";
import CTASection from "../components/sections/CTASection.astro";
import RecentPostsSection from "../components/sections/RecentPostsSection.astro";
import FAQSection from "../components/sections/FAQSection.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import PostCard from "../components/PostCard.astro";
import { getReadingTime } from "../utils/reading-time";

// ── Load site settings directly from DB (no self-fetch) ──
const settings = await getSiteSettings();
const siteTitle = settings.title || "Welcome";
const siteTagline = settings.tagline || "";

// ── Load collections dynamically — each one renders a visual section ──
type Entry = { data: Record<string, unknown>; id: string };

let services: Entry[] = [];
let team: Entry[] = [];
let testimonials: Entry[] = [];
let caseStudies: Entry[] = [];

// Safe collection loading — if collection doesn't exist, returns empty array
async function loadCollection(name: string): Promise<Entry[]> {
	try {
		const result = await getEmDashCollection(name);
		return result.entries as Entry[];
	} catch {
		return [];
	}
}

services = await loadCollection("services");
team = await loadCollection("team");
testimonials = await loadCollection("testimonials");
caseStudies = await loadCollection("case_studies");
const faqs = await loadCollection("faq");

// Posts always exist
const { entries: rawPosts, cacheHint } = await getEmDashCollection("posts");
Astro.cache.set(cacheHint);
const posts = rawPosts as Entry[];

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = (a.data.publishedAt as Date)?.getTime?.() ?? 0;
	const dateB = (b.data.publishedAt as Date)?.getTime?.() ?? 0;
	return dateB - dateA;
});

// Determine if we have a "designed" site (any collection beyond posts exists)
const hasDesignedSite = services.length > 0 || team.length > 0 || testimonials.length > 0 || caseStudies.length > 0;

// For blog fallback
const featuredPost = sortedPosts.find((p) => p.data.featured_image);
const featuredIndex = featuredPost ? sortedPosts.indexOf(featuredPost) : -1;
const gridPosts = sortedPosts.filter((_, i) => i !== featuredIndex).slice(0, 6);
const hasMorePosts = sortedPosts.length > (featuredPost ? 1 : 0) + gridPosts.length;

let featuredTags: Array<{ slug: string; label: string }> = [];
const featuredBylines = (featuredPost?.data.bylines ?? []) as Array<{ byline: { displayName: string; avatarMediaId?: string } }>;
if (featuredPost) {
	const tags = await getEntryTerms("posts", featuredPost.data.id as string, "tag");
	featuredTags = tags.map((t) => ({ slug: t.slug, label: t.label }));
}

const gridPostsWithTags = await Promise.all(
	gridPosts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id as string, "tag");
		return { post, tags: tags.map((t) => ({ slug: t.slug, label: t.label })), bylines: (post.data.bylines ?? []) as Array<{ byline: { displayName: string; avatarMediaId?: string } }> };
	})
);

function formatDate(date: unknown) {
	if (!date || !(date instanceof Date)) return null;
	return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
---

<Base title={hasDesignedSite ? siteTitle : "Home"} description={siteTagline || "Welcome"}>
	{hasDesignedSite && (
		<>
			<HeroSection
				title={siteTitle}
				subtitle={siteTagline}
				ctaText="Get Started"
				ctaUrl="/contact"
				secondaryCtaText="Learn More"
				secondaryCtaUrl="/about"
			/>

			{services.length > 0 && <ServicesGrid services={services} />}

			{caseStudies.length > 0 && <CaseStudiesGrid studies={caseStudies} />}

			{testimonials.length > 0 && <TestimonialsSection testimonials={testimonials} />}

			{team.length > 0 && <TeamGrid members={team} />}

			{faqs.length > 0 && <FAQSection faqs={faqs} />}

			{sortedPosts.length > 0 && <RecentPostsSection posts={sortedPosts.slice(0, 3)} />}

			<ContactSection />

			<CTASection />
		</>
	)}
	{!hasDesignedSite && (
		<div class="home-content">
			{posts.length === 0 ? (
				<section class="empty-state">
					<h2>Welcome to your new site</h2>
					<p>Open the AI Assistant to start building your website.</p>
					<a href="/_emdash/admin" class="btn">Open Admin</a>
				</section>
			) : (
				<>
					{featuredPost && (
						<section class="featured-section">
							<div class="featured-grid">
								<a href={`/posts/${featuredPost.id}`} class="featured-image-link">
									<div class="featured-image">
										<Image image={featuredPost.data.featured_image} />
									</div>
								</a>
								<div class="featured-content">
									<div class="featured-meta">
										{featuredBylines.length > 0 && (
											<>
												<div class="featured-bylines">
													{featuredBylines.slice(0, 2).map((credit, index) => (
														<>
															{index > 0 && <span class="byline-sep">,</span>}
															<span class="featured-byline">
																{credit.byline.avatarMediaId && <img src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`} alt={credit.byline.displayName} class="featured-byline-avatar" />}
																<span class="featured-byline-name">{credit.byline.displayName}</span>
															</span>
														</>
													))}
												</div>
												<span class="meta-dot" />
											</>
										)}
										{formatDate(featuredPost.data.publishedAt) && <time>{formatDate(featuredPost.data.publishedAt)}</time>}
										<span class="meta-dot" />
										<span>{getReadingTime(featuredPost.data.content)} min read</span>
									</div>
									<a href={`/posts/${featuredPost.id}`} class="featured-title-link">
										<h1 class="featured-title">{featuredPost.data.title}</h1>
									</a>
									{featuredPost.data.excerpt && <p class="featured-excerpt">{String(featuredPost.data.excerpt)}</p>}
									{featuredTags.length > 0 && (
										<div class="featured-tags">
											{featuredTags.map((tag) => <a href={`/tag/${tag.slug}`} class="featured-tag">{tag.label}</a>)}
										</div>
									)}
								</div>
							</div>
						</section>
					)}
					{gridPostsWithTags.length > 0 && (
						<section class="posts-section">
							<header class="section-header">
								<h2 class="section-title">Latest</h2>
								{hasMorePosts && <a href="/posts" class="section-link">View all</a>}
							</header>
							<div class="posts-grid">
								{gridPostsWithTags.map(({ post, tags, bylines }) => (
									<PostCard
										title={String(post.data.title ?? "Untitled")}
										excerpt={post.data.excerpt as string | undefined}
										featuredImage={post.data.featured_image as { src: string; alt?: string } | undefined}
										href={`/posts/${post.id}`}
										date={(post.data.publishedAt as Date) ?? undefined}
										readingTime={getReadingTime(post.data.content)}
										tags={tags}
										bylines={bylines}
									/>
								))}
							</div>
						</section>
					)}
				</>
			)}
		</div>
	)}
</Base>

<style>
	.home-content { max-width: var(--wide-width); margin: 0 auto; padding: var(--spacing-16) var(--spacing-6); }
	.featured-section { margin-bottom: var(--spacing-16); }
	.featured-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--spacing-8); align-items: center; }
	.featured-image-link { grid-column: 1 / 3; display: block; margin-left: min(-6rem, calc(-1 * (var(--spacing-6) + (100vw - var(--wide-width)) / 2))); }
	.featured-image { overflow: hidden; border-radius: 0 var(--radius-lg) var(--radius-lg) 0; background: var(--color-surface); }
	.featured-image img { width: 100%; height: auto; aspect-ratio: 4 / 3; object-fit: cover; transition: transform 0.4s ease; }
	.featured-image-link:hover .featured-image img { transform: scale(1.02); }
	.featured-content { display: flex; flex-direction: column; gap: var(--spacing-4); }
	.featured-meta { display: flex; align-items: center; flex-wrap: wrap; column-gap: var(--spacing-3); font-size: var(--font-size-sm); color: var(--color-muted); }
	.meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--color-muted); }
	.featured-bylines { display: flex; align-items: center; gap: 2px; }
	.featured-byline { display: inline-flex; align-items: center; gap: var(--spacing-2); }
	.featured-byline-avatar { width: var(--avatar-size-md); height: var(--avatar-size-md); border-radius: 50%; object-fit: cover; }
	.featured-byline-name { font-weight: 500; color: var(--color-text-secondary); }
	.featured-title-link { text-decoration: none; color: inherit; }
	.featured-title { font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl)); font-weight: 700; line-height: var(--leading-tight); transition: color var(--transition-fast); }
	.featured-title-link:hover .featured-title { color: var(--color-accent); }
	.featured-excerpt { font-size: var(--font-size-lg); line-height: var(--leading-relaxed); color: var(--color-text-secondary); }
	.featured-tags { display: flex; flex-wrap: wrap; gap: var(--spacing-2); margin-top: var(--spacing-2); }
	.featured-tag { padding: var(--spacing-1) var(--spacing-3); font-size: var(--font-size-sm); color: var(--color-text-secondary); background: var(--color-surface); border-radius: var(--radius); text-decoration: none; }
	.section-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--spacing-8); padding-bottom: var(--spacing-4); border-bottom: 1px solid var(--color-border-subtle); }
	.section-title { font-size: var(--font-size-sm); font-weight: 500; text-transform: uppercase; letter-spacing: var(--tracking-wider); color: var(--color-muted); }
	.section-link { font-size: var(--font-size-sm); color: var(--color-accent); text-decoration: none; }
	.posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--spacing-12) var(--spacing-8); }
	.empty-state { display: flex; flex-direction: column; align-items: center; gap: var(--spacing-3); text-align: center; padding: var(--spacing-20) var(--spacing-6); max-width: 400px; margin: 0 auto; }
	.empty-state h2 { font-size: var(--font-size-2xl); font-weight: 600; }
	.empty-state p { color: var(--color-muted); }
	.btn { display: inline-block; margin-top: var(--spacing-4); padding: var(--spacing-3) var(--spacing-6); background: var(--color-accent); color: var(--color-on-accent); text-decoration: none; border-radius: var(--radius); font-weight: 500; }
	@media (max-width: 900px) {
		.featured-image-link { margin-left: 0; }
		.featured-grid { grid-template-columns: 1fr; gap: var(--spacing-6); }
		.featured-image { border-radius: var(--radius-lg); }
		.posts-grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 600px) { .posts-grid { grid-template-columns: 1fr; } }
</style>
