{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "angkor-cms",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "angkor-cms",
			"database_id": "14d18775-db2e-4f76-9b00-2c7afaf8de14",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "angkor-media",
		},
	],
}
