---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

type Entry = { data: Record<string, unknown>; id: string };

let services: Entry[] = [];
try {
	const result = await getEmDashCollection("services");
	services = result.entries as Entry[];
} catch {}
---

<Base title="Our Services" description="Explore the full range of services we offer.">
	<section class="page-hero">
		<div class="page-hero-bg"></div>
		<div class="page-hero-inner">
			<h1 class="page-hero-title">Our Services</h1>
			<p class="page-hero-subtitle">Explore the full range of services we offer</p>
		</div>
	</section>

	<section class="page-content">
		<div class="page-inner">
			{services.length === 0 ? (
				<div class="empty-state">
					<p>No services have been added yet.</p>
					<a href="/_emdash/admin" class="btn">Open Admin</a>
				</div>
			) : (
				<div class="services-grid">
					{services.map((s) => (
						<a href={`/services/${s.id}`} class="service-card">
							<div class="service-icon">
								{String(s.data.icon || "").slice(0, 2) || "⚡"}
							</div>
							<h3 class="service-name">
								{String(s.data.title || s.data.name || "Untitled")}
							</h3>
							<p class="service-desc">
								{String(s.data.description || s.data.excerpt || "")}
							</p>
							<span class="service-link">Learn more &rarr;</span>
						</a>
					))}
				</div>
			)}
		</div>
	</section>
</Base>

<style>
	/* Page hero — compact version of HeroSection */
	.page-hero {
		position: relative;
		overflow: hidden;
		padding: 4rem 1.5rem;
		background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #312e81 100%);
		color: #fff;
		text-align: center;
	}
	.page-hero-bg {
		position: absolute;
		inset: 0;
		opacity: 0.07;
		background-image:
			radial-gradient(circle at 25% 25%, #fff 1px, transparent 1px),
			radial-gradient(circle at 75% 75%, #fff 1px, transparent 1px);
		background-size: 50px 50px;
	}
	.page-hero-inner {
		position: relative;
		max-width: 52rem;
		margin: 0 auto;
	}
	.page-hero-title {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.1;
		margin-bottom: 0.75rem;
	}
	.page-hero-subtitle {
		font-size: clamp(1rem, 2vw, 1.2rem);
		color: #93c5fd;
		max-width: 36rem;
		margin: 0 auto;
		line-height: 1.6;
	}

	/* Content area */
	.page-content {
		padding: 4rem 1.5rem;
		background: #fff;
	}
	.page-inner {
		max-width: 72rem;
		margin: 0 auto;
	}

	/* Grid */
	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.5rem;
	}

	/* Card — matches ServicesGrid design, now linkable */
	.service-card {
		display: flex;
		flex-direction: column;
		padding: 2rem;
		border-radius: 1rem;
		border: 1px solid #f3f4f6;
		background: #fafafa;
		text-decoration: none;
		color: inherit;
		transition: all 0.25s ease;
	}
	.service-card:hover {
		border-color: #dbeafe;
		box-shadow: 0 10px 40px rgba(59, 130, 246, 0.08);
		transform: translateY(-2px);
	}
	.service-icon {
		width: 3rem;
		height: 3rem;
		border-radius: 0.75rem;
		background: #eff6ff;
		color: #2563eb;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.5rem;
		margin-bottom: 1rem;
		transition: all 0.25s ease;
	}
	.service-card:hover .service-icon {
		background: #2563eb;
		color: #fff;
	}
	.service-name {
		font-size: 1.15rem;
		font-weight: 600;
		color: #111827;
		margin-bottom: 0.5rem;
	}
	.service-desc {
		color: #6b7280;
		font-size: 0.9rem;
		line-height: 1.65;
		flex: 1;
	}
	.service-link {
		margin-top: 1rem;
		font-size: 0.85rem;
		font-weight: 500;
		color: #2563eb;
	}

	/* Empty state */
	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		text-align: center;
		padding: 5rem 1.5rem;
		max-width: 400px;
		margin: 0 auto;
	}
	.empty-state p {
		color: #6b7280;
	}
	.btn {
		display: inline-block;
		margin-top: 1rem;
		padding: 0.75rem 1.5rem;
		background: #2563eb;
		color: #fff;
		text-decoration: none;
		border-radius: 0.5rem;
		font-weight: 500;
	}
</style>
