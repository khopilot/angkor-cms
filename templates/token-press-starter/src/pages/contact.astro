---
import Base from "../layouts/Base.astro";

let settings: Record<string, unknown> = { title: "Contact Us" };
try {
	const res = await fetch(new URL("/_emdash/api/settings", Astro.url.origin), {
		headers: { Cookie: Astro.request.headers.get("cookie") ?? "" },
	});
	if (res.ok) {
		const data = (await res.json()) as { data?: Record<string, unknown> };
		settings = data.data ?? settings;
	}
} catch {}

const siteName = String(settings.title || "Our Company");
const email = String(settings.email || settings.contactEmail || "");
const phone = String(settings.phone || settings.contactPhone || "");
const address = String(settings.address || settings.location || "");
---

<Base title="Contact Us" description={`Get in touch with ${siteName}.`}>
	<section class="page-hero">
		<div class="page-hero-bg"></div>
		<div class="page-hero-inner">
			<h1 class="page-hero-title">Get in Touch</h1>
			<p class="page-hero-subtitle">We'd love to hear from you</p>
		</div>
	</section>

	<section class="page-content">
		<div class="page-inner">
			<div class="contact-grid">
				<!-- Contact info -->
				<div class="contact-info">
					<h2 class="info-title">Contact Information</h2>
					<p class="info-desc">
						Reach out and we'll get back to you as soon as possible.
					</p>

					<div class="info-items">
						{email && (
							<div class="info-item">
								<div class="info-icon">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<rect x="2" y="4" width="20" height="16" rx="2" />
										<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
									</svg>
								</div>
								<div>
									<p class="info-label">Email</p>
									<a href={`mailto:${email}`} class="info-value">{email}</a>
								</div>
							</div>
						)}
						{phone && (
							<div class="info-item">
								<div class="info-icon">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
									</svg>
								</div>
								<div>
									<p class="info-label">Phone</p>
									<a href={`tel:${phone}`} class="info-value">{phone}</a>
								</div>
							</div>
						)}
						{address && (
							<div class="info-item">
								<div class="info-icon">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
										<circle cx="12" cy="10" r="3" />
									</svg>
								</div>
								<div>
									<p class="info-label">Address</p>
									<p class="info-value">{address}</p>
								</div>
							</div>
						)}
						{!email && !phone && !address && (
							<p class="info-fallback">
								Contact details can be configured in the CMS settings.
							</p>
						)}
					</div>
				</div>

				<!-- Contact form (visual placeholder) -->
				<div class="contact-form-wrapper">
					<form class="contact-form" onsubmit="return false;">
						<div class="form-group">
							<label for="name" class="form-label">Name</label>
							<input
								type="text"
								id="name"
								name="name"
								class="form-input"
								placeholder="Your name"
							/>
						</div>
						<div class="form-group">
							<label for="email" class="form-label">Email</label>
							<input
								type="email"
								id="email"
								name="email"
								class="form-input"
								placeholder="you@example.com"
							/>
						</div>
						<div class="form-group">
							<label for="subject" class="form-label">Subject</label>
							<input
								type="text"
								id="subject"
								name="subject"
								class="form-input"
								placeholder="How can we help?"
							/>
						</div>
						<div class="form-group">
							<label for="message" class="form-label">Message</label>
							<textarea
								id="message"
								name="message"
								class="form-input form-textarea"
								rows="5"
								placeholder="Tell us more about your project..."
							></textarea>
						</div>
						<button type="submit" class="form-submit" disabled>
							Send Message
						</button>
						<p class="form-note">
							Form submissions are not yet active. Please use the contact
							details provided.
						</p>
					</form>
				</div>
			</div>
		</div>
	</section>
</Base>

<style>
	/* Page hero */
	.page-hero {
		position: relative;
		overflow: hidden;
		padding: 4rem 1.5rem;
		background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #312e81 100%);
		color: #fff;
		text-align: center;
	}
	.page-hero-bg {
		position: absolute;
		inset: 0;
		opacity: 0.07;
		background-image:
			radial-gradient(circle at 25% 25%, #fff 1px, transparent 1px),
			radial-gradient(circle at 75% 75%, #fff 1px, transparent 1px);
		background-size: 50px 50px;
	}
	.page-hero-inner {
		position: relative;
		max-width: 52rem;
		margin: 0 auto;
	}
	.page-hero-title {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.1;
		margin-bottom: 0.75rem;
	}
	.page-hero-subtitle {
		font-size: clamp(1rem, 2vw, 1.2rem);
		color: #93c5fd;
		max-width: 36rem;
		margin: 0 auto;
		line-height: 1.6;
	}

	/* Content */
	.page-content {
		padding: 4rem 1.5rem;
		background: #fff;
	}
	.page-inner {
		max-width: 72rem;
		margin: 0 auto;
	}

	/* Two-column layout */
	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 4rem;
		align-items: start;
	}

	/* Contact info */
	.contact-info {
		padding: 2.5rem;
		background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
		border-radius: 1rem;
		color: #fff;
	}
	.info-title {
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
	}
	.info-desc {
		color: #93c5fd;
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 2rem;
	}
	.info-items {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.info-item {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
	}
	.info-icon {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.5rem;
		background: rgba(255, 255, 255, 0.1);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		color: #93c5fd;
	}
	.info-label {
		font-size: 0.8rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #93c5fd;
		margin-bottom: 0.2rem;
	}
	.info-value {
		font-size: 0.95rem;
		color: #fff;
		text-decoration: none;
	}
	a.info-value:hover {
		text-decoration: underline;
	}
	.info-fallback {
		color: #93c5fd;
		font-size: 0.9rem;
		font-style: italic;
	}

	/* Form */
	.contact-form-wrapper {
		padding: 2.5rem;
		border: 1px solid #f3f4f6;
		border-radius: 1rem;
		background: #fafafa;
	}
	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}
	.form-label {
		font-size: 0.875rem;
		font-weight: 500;
		color: #374151;
	}
	.form-input {
		padding: 0.625rem 0.875rem;
		border: 1px solid #d1d5db;
		border-radius: 0.5rem;
		font-size: 0.95rem;
		font-family: inherit;
		background: #fff;
		color: #111827;
		transition: border-color 0.2s;
	}
	.form-input:focus {
		outline: none;
		border-color: #2563eb;
		box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
	}
	.form-input::placeholder {
		color: #9ca3af;
	}
	.form-textarea {
		resize: vertical;
		min-height: 120px;
	}
	.form-submit {
		padding: 0.75rem 1.75rem;
		background: #2563eb;
		color: #fff;
		font-weight: 600;
		font-size: 0.95rem;
		border: none;
		border-radius: 0.5rem;
		cursor: not-allowed;
		opacity: 0.6;
		font-family: inherit;
		transition: all 0.2s;
	}
	.form-note {
		font-size: 0.8rem;
		color: #9ca3af;
		text-align: center;
		font-style: italic;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.contact-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
