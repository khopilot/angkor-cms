---
interface Props {
	title: string;
	subtitle?: string;
	ctaText?: string;
	ctaUrl?: string;
	secondaryCtaText?: string;
	secondaryCtaUrl?: string;
}
const {
	title,
	subtitle,
	ctaText = "Get Started",
	ctaUrl = "/contact",
	secondaryCtaText,
	secondaryCtaUrl,
} = Astro.props;
---
<section class="hero">
	<div class="hero-bg"></div>
	<div class="hero-inner">
		<h1 class="hero-title">{title}</h1>
		{subtitle && <p class="hero-subtitle">{subtitle}</p>}
		<div class="hero-actions">
			<a href={ctaUrl} class="btn-primary">{ctaText}</a>
			{secondaryCtaText && (
				<a href={secondaryCtaUrl ?? "#"} class="btn-secondary">{secondaryCtaText}</a>
			)}
		</div>
	</div>
</section>
<style>
	:root {
		--tp-primary: #2563eb;
		--tp-secondary: #7c3aed;
		--tp-accent: #f59e0b;
	}

	.hero {
		position: relative;
		overflow: hidden;
		padding: 7rem 1.5rem 6rem;
		background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #312e81 100%);
		color: #fff;
		text-align: center;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		opacity: 0.06;
		background-image:
			radial-gradient(circle at 20% 30%, #fff 1px, transparent 1px),
			radial-gradient(circle at 80% 70%, #fff 1px, transparent 1px);
		background-size: 40px 40px;
		animation: heroFloat 20s ease-in-out infinite;
	}

	@keyframes heroFloat {
		0%, 100% { transform: translate(0, 0); }
		25% { transform: translate(-8px, -6px); }
		50% { transform: translate(4px, -12px); }
		75% { transform: translate(-4px, 6px); }
	}

	.hero-inner {
		position: relative;
		max-width: 52rem;
		margin: 0 auto;
	}

	.hero-title {
		font-size: clamp(3rem, 7vw, 5rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.08;
		margin: 0 0 1.5rem;
	}

	.hero-subtitle {
		font-size: clamp(1.1rem, 2.5vw, 1.35rem);
		color: #93c5fd;
		max-width: 38rem;
		margin: 0 auto 2.5rem;
		line-height: 1.7;
		font-weight: 400;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		padding: 0.9rem 2.25rem;
		background: #fff;
		color: #0f172a;
		font-weight: 600;
		border-radius: 0.5rem;
		text-decoration: none;
		font-size: 1rem;
		transition: all 0.25s ease;
		box-shadow: 0 4px 14px rgba(0, 0, 0, 0.1);
	}

	.btn-primary:hover {
		background: #e0f2fe;
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
	}

	.btn-secondary {
		display: inline-flex;
		align-items: center;
		padding: 0.9rem 2.25rem;
		border: 2px solid rgba(255, 255, 255, 0.3);
		border-radius: 0.5rem;
		color: #fff;
		text-decoration: none;
		font-size: 1rem;
		font-weight: 500;
		transition: all 0.25s ease;
		background: transparent;
	}

	.btn-secondary:hover {
		background: rgba(255, 255, 255, 0.1);
		border-color: rgba(255, 255, 255, 0.55);
		transform: translateY(-1px);
	}

	@media (max-width: 600px) {
		.hero {
			padding: 4.5rem 1.25rem 3.5rem;
		}
		.hero-actions {
			flex-direction: column;
			align-items: center;
		}
	}
</style>
